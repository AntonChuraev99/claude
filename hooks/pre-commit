#!/usr/bin/env bash
# ============================================================================
#  Anti-leak pre-commit hook — TEMPLATE.
#
#  This repo is a personal Claude Code config kept under git. Because the
#  working files ARE the published files, day-to-day edits can accidentally
#  reintroduce private project names or secrets. This hook blocks a commit
#  when staged content matches a denylist.
#
#  INSTALL in your clone:
#      cp hooks/pre-commit .git/hooks/pre-commit
#      chmod +x .git/hooks/pre-commit
#      # then edit the denylist below with YOUR private names
#
#  The live copy in .git/hooks/ is never tracked by git, so your real
#  denylist stays local.
# ============================================================================

# --- Your private project names / personal identifiers (EDIT THESE) ----------
denylist='yourproject|yourapp|your-company|yourusername'

# --- Your private numeric IDs (analytics / cloud project numbers) ------------
ids='000000|111111'

# --- Generic secret patterns + your home path (EDIT the path) ----------------
secrets='sk-ant-|AIza[0-9A-Za-z_-]{20,}|ghp_[0-9A-Za-z]{20,}|xox[bp]-|BEGIN [A-Z ]*PRIVATE KEY|Users[\\/]YOURNAME|@yourmail\.com'

pattern="$denylist|$ids|$secrets"

fail=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  # Skip files that legitimately contain denylist/secret-pattern STRINGS
  # (this hook template, .gitignore, .gitattributes) — they hold regexes, not data.
  case "$f" in hooks/*|.gitignore|.gitattributes) continue;; esac
  match=$(git show ":$f" 2>/dev/null | grep -nEi "$pattern")
  if [ -n "$match" ]; then
    if [ "$fail" -eq 0 ]; then
      echo "============================================================"
      echo " X  COMMIT BLOCKED -- private data / secret detected"
      echo "============================================================"
      fail=1
    fi
    echo ""
    echo "  $f:"
    echo "$match" | sed 's/^/    /'
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "$fail" -eq 1 ]; then
  echo ""
  echo "------------------------------------------------------------"
  echo " Generalize names, remove secrets, then re-stage."
  echo " False positive? edit the denylist in .git/hooks/pre-commit,"
  echo " or bypass once with:  git commit --no-verify  (discouraged)"
  echo "------------------------------------------------------------"
  exit 1
fi

# --- Optional deeper secret scan if gitleaks is installed --------------------
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner --redact 2>/dev/null || {
    echo "X gitleaks detected a secret in staged changes. Commit blocked."
    exit 1
  }
fi

exit 0
